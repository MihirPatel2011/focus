rules_version = '2';

// Per-user data isolation. Every document lives under users/{uid}/... and is
// readable/writable ONLY by the authenticated owner. Since the web client is
// fully public (config keys ship in the bundle), THIS is the real security
// boundary — keep it tight.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // The user profile document itself (optional; owner-only).
      allow read, write: if isOwner(uid);

      // All app collections are scoped under the user and owner-locked.
      match /{collection}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
