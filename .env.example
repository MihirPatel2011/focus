# Firebase web config — these are NOT secrets (they ship in the client bundle).
# Security is enforced by Firestore rules + Auth, not by hiding these values.
# Copy this file to `.env` and fill in values from your Firebase project settings.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef

# Optional: override the Vite base path (default "/focus/" for GitHub Pages).
# For a custom domain set this to "/".
# VITE_BASE_PATH=/focus/
